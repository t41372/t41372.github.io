# PostHog analytics — copy to `.env` (gitignored) to enable locally.
# When PUBLIC_POSTHOG_KEY is empty/unset, analytics silently no-ops, so local
# dev stays clean. See src/lib/posthog.ts.
#
# NOTE: the project API key (phc_...) is a PUBLIC/publishable key — it ships in
# the client JS bundle by design. Storing it as a GitHub Actions secret or in a
# gitignored .env just keeps it out of source control; it is not truly secret.

# Project API key — PostHog → Settings → Project → "Project API Key" (starts with phc_)
PUBLIC_POSTHOG_KEY=

# Ingestion host for your PostHog region. Optional — defaults to US cloud.
#   US cloud: https://us.i.posthog.com   (default if left blank)
#   EU cloud: https://eu.i.posthog.com
PUBLIC_POSTHOG_HOST=
