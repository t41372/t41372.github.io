---
import HeroIntro from './HeroIntro'
---

<!-- a transparent "skylight": the fixed StarSky canvas shows through; the
     intro text parallaxes slower than the page (rellax) so the projects
     panel visibly slides over it -->
<section class="relative h-svh w-full overflow-hidden" aria-label="Introduction">
  <div class="absolute inset-0 flex items-end">
    <div class="mx-auto w-full max-w-6xl px-6 pb-24 md:px-10 md:pb-28">
      <div class="rellax max-w-3xl" data-rellax-speed="-2">
        <HeroIntro client:load />
      </div>
    </div>
  </div>
</section>
