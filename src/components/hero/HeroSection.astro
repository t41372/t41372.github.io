---
import AuroraBackground from './AuroraBackground'
import HeroIntro from './HeroIntro'
---

<section class="relative h-svh w-full overflow-hidden bg-background" aria-label="Introduction">
  <AuroraBackground client:load />

  <div class="absolute inset-0 flex items-center">
    <div class="mx-auto w-full max-w-6xl px-6 md:px-10">
      <div class="max-w-3xl">
        <HeroIntro client:load />
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-6 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2"
    aria-hidden="true"
  >
    <span class="font-mono text-[10px] font-medium uppercase tracking-[0.35em] text-muted">
      Scroll
    </span>
    <span class="scroll-line block h-8 w-px bg-foreground/30"></span>
  </div>

  <!-- soft fade into the projects section -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-background"
    aria-hidden="true"
  >
  </div>
</section>
