---
const { active = 'home' } = Astro.props as { active?: 'home' | 'projects' | 'blog' }

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/projects', label: 'Projects', key: 'projects' },
  { href: '/blog', label: 'Blog', key: 'blog' },
]
---

<!-- transition:persist keeps this exact header DOM alive across client-side
     navigations, so the highlight pill below is ONE persistent element that
     slides between links via a plain CSS transform transition. No
     view-transition snapshots are involved: those render above the page and
     stretch between old/new sizes, which is what previously made the pill
     cover the text and jump around. -->
<header transition:persist="site-header" class="fixed inset-x-0 top-4 z-50 flex justify-center px-4">
  <nav
    aria-label="Main navigation"
    data-nav
    class="relative flex items-center gap-1 rounded-full border border-border-subtle/60 bg-background/50 px-1.5 py-1.5 shadow-lg shadow-black/20 backdrop-blur-md"
  >
    <span
      aria-hidden="true"
      data-nav-pill
      class="absolute left-0 top-0 z-0 rounded-full bg-surface-raised opacity-0 motion-safe:[&.is-ready]:transition-[transform,width,height] motion-safe:[&.is-ready]:duration-300 motion-safe:[&.is-ready]:ease-[cubic-bezier(0.3,0.9,0.35,1)]"></span>
    {
      links.map((link) => (
        <a
          href={link.href}
          data-nav-key={link.key}
          aria-current={active === link.key ? 'page' : undefined}
          class:list={[
            'relative z-10 rounded-full px-4 py-1.5 font-mono text-sm transition-colors duration-200',
            active === link.key
              ? 'text-foreground'
              : 'text-muted hover:bg-surface/80 hover:text-foreground',
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const ROUTE_KEYS: Array<[RegExp, string]> = [
    [/^\/blog(\/|$)/, 'blog'],
    [/^\/projects(\/|$)/, 'projects'],
    [/^\/$/, 'home'],
  ]

  const activeKey = () =>
    ROUTE_KEYS.find(([re]) => re.test(location.pathname))?.[1] ?? 'home'

  function updateNav() {
    const nav = document.querySelector<HTMLElement>('[data-nav]')
    const pill = nav?.querySelector<HTMLElement>('[data-nav-pill]')
    if (!nav || !pill) return

    const key = activeKey()
    let target: HTMLElement | null = null

    for (const link of nav.querySelectorAll<HTMLElement>('a[data-nav-key]')) {
      const isActive = link.dataset.navKey === key
      link.classList.toggle('text-foreground', isActive)
      link.classList.toggle('text-muted', !isActive)
      link.classList.toggle('hover:bg-surface/80', !isActive)
      link.classList.toggle('hover:text-foreground', !isActive)
      if (isActive) {
        link.setAttribute('aria-current', 'page')
        target = link
      } else {
        link.removeAttribute('aria-current')
      }
    }
    if (!target) return

    pill.style.width = `${target.offsetWidth}px`
    pill.style.height = `${target.offsetHeight}px`
    pill.style.transform = `translate(${target.offsetLeft}px, ${target.offsetTop}px)`
    pill.style.opacity = '1'

    // first positioning happens without a transition (no fly-in from 0,0);
    // every later move slides
    if (!pill.classList.contains('is-ready')) {
      requestAnimationFrame(() => pill.classList.add('is-ready'))
    }
  }

  // initial load + after every client-side swap (before the page fade ends,
  // so the slide runs alongside it)
  document.addEventListener('astro:page-load', updateNav)
  document.addEventListener('astro:after-swap', updateNav)
  window.addEventListener('resize', updateNav)
</script>
