---
const { active = 'home' } = Astro.props as { active?: 'home' | 'projects' | 'blog' }

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/projects', label: 'Projects', key: 'projects' },
  { href: '/blog', label: 'Blog', key: 'blog' },
]
---

<header class="fixed inset-x-0 top-4 z-50 flex justify-center px-4">
  <nav
    aria-label="Main navigation"
    class="flex items-center gap-1 rounded-full border border-border-subtle/60 bg-background/50 px-1.5 py-1.5 shadow-lg shadow-black/20 backdrop-blur-md"
  >
    {
      links.map((link) => (
        <a
          href={link.href}
          aria-current={active === link.key ? 'page' : undefined}
          class:list={[
            'rounded-full px-4 py-1.5 font-mono text-sm transition-colors duration-200',
            active === link.key
              ? 'bg-surface-raised text-foreground'
              : 'text-muted hover:bg-surface/80 hover:text-foreground',
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>
