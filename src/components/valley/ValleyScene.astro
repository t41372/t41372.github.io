---
// ValleyScene.astro
// A minimalist, handcrafted poly-style SVG illustration of a valley and cabin.
---

<section
  class="relative w-full z-10 flex flex-col justify-end"
  aria-label="A quiet valley at night with a small cabin"
>
  <svg 
    viewBox="0 0 1440 600" 
    preserveAspectRatio="xMidYMax slice" 
    class="w-full h-[50vh] md:h-[65vh] lg:h-[80vh] block object-bottom pointer-events-none select-none" 
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#ffb74d" stop-opacity="0.8" />
        <stop offset="100%" stop-color="#ffb74d" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="beam" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#ffb74d" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#ffb74d" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="mnt1" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#1c2135" />
        <stop offset="100%" stop-color="#131728" />
      </linearGradient>
      <linearGradient id="mnt2" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#131728" />
        <stop offset="100%" stop-color="#0b0e17" />
      </linearGradient>
      <linearGradient id="mnt3" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#0b0e17" />
        <stop offset="100%" stop-color="#07090f" />
      </linearGradient>
      <linearGradient id="mnt-ground" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#07090f" />
        <stop offset="100%" stop-color="#05070b" />
      </linearGradient>
    </defs>

    <!-- Far Mountains (Mnt 1) -->
    <path d="M0,600 L0,280 L200,210 L350,320 L500,180 L650,290 L800,150 L950,280 L1100,190 L1300,300 L1440,240 L1440,600 Z" fill="url(#mnt1)" />
    <path d="M200,210 L350,320 L300,600 L0,600 Z" fill="#171b2d" opacity="0.4" />
    <path d="M500,180 L650,290 L600,600 L350,600 Z" fill="#171b2d" opacity="0.4" />
    <path d="M800,150 L950,280 L900,600 L650,600 Z" fill="#171b2d" opacity="0.4" />
    <path d="M1100,190 L1300,300 L1250,600 L950,600 Z" fill="#171b2d" opacity="0.4" />

    <!-- Mid Mountains (Mnt 2) -->
    <path d="M0,600 L0,380 L300,250 L450,380 L600,220 L800,400 L950,280 L1150,420 L1250,350 L1440,430 L1440,600 Z" fill="url(#mnt2)" />
    <path d="M300,250 L450,380 L400,600 L100,600 Z" fill="#0f121e" opacity="0.5" />
    <path d="M600,220 L800,400 L750,600 L450,600 Z" fill="#0f121e" opacity="0.5" />
    <path d="M950,280 L1150,420 L1100,600 L800,600 Z" fill="#0f121e" opacity="0.5" />

    <!-- Near Mountains / Hills (Mnt 3) -->
    <path d="M0,600 L0,480 L450,420 L695,345 L770,345 L1050,450 L1440,400 L1440,600 Z" fill="url(#mnt3)" />
    <path d="M450,420 L695,345 L730,600 L250,600 Z" fill="#080b12" opacity="0.6" />
    <path d="M770,345 L1050,450 L1250,600 L800,600 Z" fill="#080b12" opacity="0.6" />

    <!-- Ground -->
    <path d="M0,600 L0,550 L300,500 L600,550 L1000,490 L1440,540 L1440,600 Z" fill="url(#mnt-ground)" />
    <path d="M300,500 L600,550 L550,600 L100,600 Z" fill="#05070a" opacity="0.4" />
    <path d="M1000,490 L1440,540 L1440,600 L800,600 Z" fill="#05070a" opacity="0.4" />

    <!-- Cabin on the plateau at x=695..770, y=345 -->
    <g transform="translate(700, 280)">
      <!-- Cabin Front -->
      <polygon points="0,65 0,25 25,0 50,25 50,65" fill="#06080c"/>
      <!-- Cabin Side -->
      <polygon points="50,25 110,45 110,85 50,65" fill="#080a0f"/>
      
      <!-- Roof Front (gable end, rake parallel to the wall gable) -->
      <polygon points="-11,29 25,-7 61,29" fill="#0d111a"/>
      <!-- Roof Side -->
      <polygon points="25,-7 85,13 121,49 61,29" fill="#161b2e"/>

      <!-- Chimney (on the near slope, beside the ridge) -->
      <polygon points="46,-18 54,-18 54,11 46,3" fill="#06080c"/>
      <polygon points="54,-18 60,-16 60,13 54,11" fill="#080a0f"/>

      <!-- Window Glow -->
      <ellipse cx="74" cy="52" rx="46" ry="30" fill="url(#glow)" opacity="0.25"/>

      <!-- Window -->
      <polygon points="62,40 86,48 86,64 62,56" fill="#ffb74d"/>
      <polygon points="62,40 86,48 86,64 62,56" fill="#ffffff" opacity="0.4"/>
      
      <!-- Window Frame (Cross) -->
      <line x1="74" y1="44" x2="74" y2="60" stroke="#06080c" stroke-width="2" />
      <line x1="62" y1="48" x2="86" y2="56" stroke="#06080c" stroke-width="2" />
    </g>

    <!-- Ground Flat Base to ensure it seamlessly connects with footer -->
    <rect x="0" y="580" width="1440" height="20" fill="#05070B" />
  </svg>
</section>
